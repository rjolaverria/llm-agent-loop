{
  "name": "llm-agent-loop",
  "version": "2.0.0",
  "description": "A lightweight, provider-agnostic agent loop for building LLM agents.",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "type": "module",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist",
    "src/index.ts"
  ],
  "scripts": {
    "build": "tsc",
    "test": "vitest run",
    "test:watch": "vitest",
    "coverage": "vitest run --coverage",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "prepublishOnly": "npm run build",
    "prepare": "husky || true"
  },
  "lint-staged": {
    "*.{ts,js}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md,yml,yaml}": [
      "prettier --write"
    ]
  },
  "keywords": [
    "llm",
    "agent",
    "agent-loop",
    "ai",
    "openai",
    "anthropic",
    "gemini",
    "tool-use",
    "typescript"
  ],
  "author": "Rafi Olaverria",
  "license": "ISC",
  "engines": {
    "node": ">=22.13.0"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/rjolaverria/llm-agent-loop.git"
  },
  "devDependencies": {
    "@anthropic-ai/sdk": "^0.70.1",
    "@eslint/js": "^10.0.1",
    "@google/generative-ai": "^0.24.1",
    "@vitest/coverage-v8": "^4.1.9",
    "eslint": "^10.6.0",
    "eslint-config-prettier": "^10.1.8",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "openai": "^6.9.1",
    "prettier": "^3.9.5",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.63.0",
    "vitest": "^4.1.9"
  }
}
